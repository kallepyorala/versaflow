{
  "name": "versaflow-react",
  "version": "0.1.0",
  "description": "Versaflow Cockpit — Electron + React + TypeScript",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "sidecar:build": "cargo build --release --manifest-path sidecar/Cargo.toml"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  }
}
